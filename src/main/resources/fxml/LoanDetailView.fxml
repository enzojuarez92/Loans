<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<VBox prefWidth="800.0" prefHeight="700.0" spacing="0" styleClass="view-root"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.edj.developer.apploans.controller.LoanDetailController">

    <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12">
        <VBox alignment="CENTER_LEFT" spacing="2">
            <Label fx:id="lblCustomerName" text="Cargando Cliente" styleClass="topbar-title"/>
            <HBox spacing="6" alignment="CENTER_LEFT">
                <Label text="Panel Principal" styleClass="breadcrumb-link"/>
                <Label text="/" styleClass="text-muted"/>
                <Label text="Prestamos" styleClass="breadcrumb-link"/>
                <Label text="/" styleClass="text-muted"/>
                <Label text="Detalle Prestamo" styleClass="text-muted text-sm"/>
            </HBox>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnCancelLoan" text="Anular Prestamo" onAction="#handleCancelLoan" styleClass="btn,btn-danger" mnemonicParsing="false" style="-fx-background-color: #dc3545; -fx-text-fill: white;">
            <graphic><FontIcon iconLiteral="fas-trash-alt" iconColor="white"/></graphic>
        </Button>
        <Button text="Volver" onAction="#handleBack" styleClass="btn,btn-primary" mnemonicParsing="false">
            <graphic><FontIcon iconLiteral="fas-arrow-left"/></graphic>
        </Button>
    </HBox>

    <ScrollPane fitToWidth="true" styleClass="edge-to-edge" VBox.vgrow="ALWAYS">
        <VBox spacing="20" style="-fx-padding: 20;">

            <HBox spacing="15">
                <VBox styleClass="stat-card,stat-card-primary" HBox.hgrow="ALWAYS">
                    <Label text="TOTAL A PAGAR" styleClass="stat-label"/>
                    <Label fx:id="lblTotalAmount" text="0.00" styleClass="stat-value"/>
                </VBox>
                <VBox styleClass="stat-card,stat-card-success" HBox.hgrow="ALWAYS">
                    <Label text="TOTAL PAGADO" styleClass="stat-label"/>
                    <Label fx:id="lblPaidAmount" text="0.00" styleClass="stat-value"/>
                </VBox>
                <VBox styleClass="stat-card,stat-card-danger" HBox.hgrow="ALWAYS">
                    <Label text="SALDO PENDIENTE" styleClass="stat-label"/>
                    <Label fx:id="lblPendingAmount" text="0.00" styleClass="stat-value"/>
                </VBox>
            </HBox>

            <VBox styleClass="card">
                <HBox styleClass="card-header" spacing="10" alignment="CENTER_LEFT">
                    <FontIcon iconLiteral="fas-calendar-alt" iconSize="15" iconColor="#495057"/>
                    <Label fx:id="lblLoanId" text="Préstamo #000" styleClass="card-title"/>
                    <Label text=" - " styleClass="card-title" />
                    <Label text="Cronograma de Cuotas" styleClass="card-title"/>
                    <Region HBox.hgrow="ALWAYS"/>

                    <Button fx:id="btnRegisterPayment" onAction="#handleOpenPaymentModal" text="Registrar Cobro" styleClass="btn,btn-success" style="-fx-background-color: #198754; -fx-text-fill: white;" mnemonicParsing="false">
                        <graphic><FontIcon iconLiteral="fas-plus-circle" iconColor="white"/></graphic>
                    </Button>

                    <Button onAction="#handleGenerateReport" text="Ver Resumen" styleClass="btn,btn-primary" mnemonicParsing="false">
                        <graphic><FontIcon iconLiteral="fas-file"/></graphic>
                    </Button>
                </HBox>

                <TableView fx:id="tablePayments" prefHeight="300.0" styleClass="app-table" VBox.vgrow="NEVER">
                    <columns>
                        <TableColumn fx:id="colNumber" text="N°" prefWidth="50" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colDueDate" text="VENCIMIENTO" prefWidth="120" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colPaymentDate" text="ÚLT. PAGO" prefWidth="120" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colAmount" text="TOTAL CUOTA" prefWidth="120" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colPaidAmount" text="PAGADO" prefWidth="120" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colBalance" text="SALDO" prefWidth="120" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colStatus" text="ESTADO" prefWidth="140" style="-fx-alignment: CENTER;"/>
                    </columns>
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                </TableView>
            </VBox>

            <VBox styleClass="card">
                <HBox styleClass="card-header" spacing="10" alignment="CENTER_LEFT">
                    <FontIcon iconLiteral="fas-history" iconSize="15" iconColor="#495057"/>
                    <Label text="Historial de Pagos Recibidos (Entregas)" styleClass="card-title"/>
                </HBox>

                <TableView fx:id="tableHistory" prefHeight="220.0" styleClass="app-table" VBox.vgrow="NEVER">
                    <columns>
                        <TableColumn fx:id="colHistId" text="N° RECIBO" prefWidth="100" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colHistDate" text="FECHA / HORA" prefWidth="180" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colHistAmount" text="MONTO ENTREGADO" prefWidth="150" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="colHistNotes" text="NOTAS / DETALLE" prefWidth="300" style="-fx-alignment: CENTER_LEFT;"/>
                        <TableColumn fx:id="colHistActions" text="ACCIONES" prefWidth="80" style="-fx-alignment: CENTER;"/>
                    </columns>
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                </TableView>
            </VBox>

        </VBox>
    </ScrollPane>
</VBox>