<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<VBox spacing="15" style="-fx-padding: 25; -fx-background-color: white;" prefWidth="350"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.edj.developer.apploans.controller.PaymentModalController">

    <Label text="Registrar Pago" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
    <Separator/>

    <VBox spacing="5">
        <Label text="Saldo Pendiente de la Cuota:" style="-fx-text-fill: #6c757d;"/>
        <Label fx:id="lblPending" text="0.00" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #dc3545;"/>
    </VBox>

    <VBox spacing="5">
        <Label text="Monto a Cobrar:"/>
        <TextField fx:id="txtAmountToPay" style="-fx-font-size: 16;"/>
    </VBox>

    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
        <Button text="Cancelar" onAction="#handleCancel" styleClass="btn, btn-light"/>
        <Button text="Confirmar Pago" onAction="#handleConfirm" styleClass="btn, btn-success">
            <graphic><FontIcon iconLiteral="fas-check"/></graphic>
        </Button>
    </HBox>
</VBox>