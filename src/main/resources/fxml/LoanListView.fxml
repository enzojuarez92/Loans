<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.edj.developer.apploans.controller.LoanListController"
      styleClass="view-root" spacing="0">

    <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12">
        <VBox alignment="CENTER_LEFT" spacing="2">
            <Label text="Gestión de Préstamos" styleClass="topbar-title"/>
            <HBox spacing="6" alignment="CENTER_LEFT">
                <Label text="Panel Principal" styleClass="breadcrumb-link"/>
                <Label text="/" styleClass="text-muted"/>
                <Label text="Préstamos" styleClass="text-muted text-sm"/>
            </HBox>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnNewLoan" text="Nuevo Préstamo" onAction="#handleNewLoan"
                styleClass="btn,btn-primary">
            <graphic>
                <FontIcon iconLiteral="fas-plus-circle" iconSize="14" iconColor="white"/>
            </graphic>
        </Button>
    </HBox>

    <HBox spacing="16" styleClass="stats-bar">
        <VBox styleClass="stat-card,stat-card-primary" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="14">
                <FontIcon iconLiteral="fas-file-invoice-dollar" iconSize="24" styleClass="stat-icon-primary"/>
                <VBox>
                    <Label fx:id="lblTotalLoans" text="0" styleClass="stat-value"/>
                    <Label text="TOTAL PRÉSTAMOS" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>
        <VBox styleClass="stat-card,stat-card-success" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="14">
                <FontIcon iconLiteral="fas-hand-holding-usd" iconSize="24" styleClass="stat-icon-success"/>
                <VBox>
                    <Label fx:id="lblActiveAmount" text="0.00" styleClass="stat-value"/>
                    <Label text="MONTO ACTIVO" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>
    </HBox>

    <VBox VBox.vgrow="ALWAYS" styleClass="card" spacing="0">
        <HBox styleClass="card-header" spacing="10" alignment="CENTER_LEFT">
            <FontIcon iconLiteral="fas-list" iconSize="15" iconColor="#495057"/>
            <Label text="Listado de Préstamos" styleClass="card-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField fx:id="txtSearch" promptText="Buscar prestamo..." styleClass="search-field" prefWidth="250"/>

            <ComboBox fx:id="cmbStatusFilter"
                      promptText="Todos los estados"
                      styleClass="form-control"
                      prefWidth="160"/>

            <Button onAction="#handleRefresh" styleClass="btn,btn-secondary,btn-sm">
                <graphic><FontIcon iconLiteral="fas-sync-alt"/></graphic>
            </Button>
        </HBox>

        <TableView fx:id="tableLoans" VBox.vgrow="ALWAYS" styleClass="app-table">
            <columns>
                <TableColumn fx:id="colId" text="#" prefWidth="50" style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="colCustomer" text="CLIENTE" prefWidth="180"/>
                <TableColumn fx:id="colAmount" text="MONTO PRESTADO" prefWidth="140" style="-fx-alignment: CENTER-RIGHT;"/>
                <TableColumn fx:id="colTotal" text="TOTAL A PAGAR" prefWidth="140" style="-fx-alignment: CENTER-RIGHT;"/>
                <TableColumn fx:id="colInstallments" text="PLAN" prefWidth="140" style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="colFrequency" text="FRECUENCIA" prefWidth="120" style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="colDate" text="FECHA" prefWidth="110" style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="colStatus" text="ESTADO" prefWidth="100" minWidth="80"/>
                <TableColumn fx:id="colActions" text="ACCIONES" prefWidth="90" style="-fx-alignment: CENTER;"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>

        <HBox styleClass="card-footer" spacing="12" alignment="CENTER">
            <Label fx:id="lblPageInfo" text="Mostrando 0 – 0 de 0 registros" styleClass="text-muted text-sm"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="6" alignment="CENTER">
                <Label text="Ver:" styleClass="text-muted text-sm"/>
                <ComboBox fx:id="cmbPageSize" prefWidth="100" styleClass="form-control"/>
                <Label text="por pág." styleClass="text-muted text-sm"/>
            </HBox>
            <Pagination fx:id="pagination" pageCount="1" currentPageIndex="0" styleClass="pagination" HBox.hgrow="NEVER"/>
        </HBox>
    </VBox>
</VBox>