<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<VBox prefWidth="750.0" style="-fx-background-color: #eeeeee;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.edj.developer.apploans.controller.ReportController">

    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 10; -fx-background-color: #343a40;">
        <Button text="Imprimir" onAction="#handlePrint" styleClass="btn,btn-primary">
            <graphic>
                <FontIcon iconLiteral="fas-print" iconColor="white"/>
            </graphic>
        </Button>
        <Button text="Cerrar" onAction="#handleClose" styleClass="btn,btn-danger">
            <graphic>
                <FontIcon iconLiteral="fas-times" iconColor="white"/>
            </graphic>
        </Button>
    </HBox>

    <VBox fx:id="reportContainer" spacing="20" style="-fx-padding: 40; -fx-background-color: white;" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT">
            <VBox spacing="5">
                <Label text="RESUMEN DE CUENTA" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #25467E;"/>
                <Label fx:id="lblReportCustomer" text="Cliente: ..." style="-fx-font-size: 16;"/>
                <Label fx:id="lblReportDate" text="Fecha de emisión: ..." style="-fx-text-fill: gray;"/>
                <Label fx:id="lblLoanId" text="Préstamo #000" style="-fx-font-weight: bold;"/>
            </VBox>
        </HBox>

        <Separator/>

        <TableView fx:id="tableReport" prefHeight="500" style="-fx-background-color: white;">
            <columns>
                <TableColumn fx:id="colNum" prefWidth="60" text="N° REC." style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="colDate" prefWidth="180" text="FECHA DE PAGO" style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="colAmount" prefWidth="180" text="MONTO ENTREGADO" style="-fx-alignment: CENTER_RIGHT;"/>
                <TableColumn fx:id="colNotes" prefWidth="250" text="DETALLE / CONCEPTO" style="-fx-alignment: CENTER;"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="20">
            <VBox alignment="CENTER_RIGHT" spacing="5">
                <Label text="RESUMEN FINANCIERO" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #6c757d;"/>
                <HBox spacing="10">
                    <Label text="TOTAL PAGADO:"/>
                    <Label fx:id="lblTotalPaid" text="0.00" style="-fx-font-weight: bold;"/>
                </HBox>
                <HBox spacing="10">
                    <Label text="TOTAL PENDIENTE:" style="-fx-text-fill: #dc3545;"/>
                    <Label fx:id="lblReportTotalPending" text="0.00" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #dc3545;"/>
                </HBox>
            </VBox>
        </HBox>
    </VBox>
</VBox>