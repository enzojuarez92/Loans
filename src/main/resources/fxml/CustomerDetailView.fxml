<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.edj.developer.apploans.controller.CustomerDetailController"
      prefWidth="650.0" prefHeight="550.0"
      style="-fx-background-color: #f8f9fa; -fx-padding: 20;" spacing="15">

    <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-border-color: #dee2e6; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 10 0;">
        <FontIcon iconLiteral="fas-user-circle" iconSize="36" iconColor="#0d6efd"/>
        <VBox>
            <Label fx:id="lblCustomerName" text="Nombre del Cliente" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Label fx:id="lblCustomerDoc" text="Doc: 00000000" styleClass="text-muted"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblStatusBadge" text="ACTIVO" style="-fx-padding: 5 10; -fx-background-radius: 4; -fx-font-weight: bold;"/>
    </HBox>

    <HBox spacing="10">
        <VBox styleClass="stat-card stat-card-primary" HBox.hgrow="ALWAYS" style="-fx-padding: 10;">
            <Label text="Préstamos Totales" styleClass="stat-label"/>
            <Label fx:id="lblTotalLoans" text="0" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
        </VBox>
        <VBox styleClass="stat-card stat-card-warning" HBox.hgrow="ALWAYS" style="-fx-padding: 10;">
            <Label text="Saldo Pendiente" styleClass="stat-label"/>
            <Label fx:id="lblPendingBalance" text="0.00" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #b58105;"/>
        </VBox>
    </HBox>

    <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE" style="-fx-background-color: white; -fx-background-radius: 6; -fx-border-color: #dee2e6; -fx-border-radius: 6;">
        <Tab text="Datos Personales">
            <graphic><FontIcon iconLiteral="fas-id-card"/></graphic>
            <GridPane hgap="15" vgap="10" style="-fx-padding: 15;">
                <columnConstraints>
                    <ColumnConstraints prefWidth="120" />
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="Teléfono:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Label fx:id="lblPhone" text="-" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Email:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <Label fx:id="lblEmail" text="-" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Dirección:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <Label fx:id="lblAddress" text="-" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="Ciudad:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <Label fx:id="lblCity" text="-" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                <Label text="F. Nacimiento:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <Label fx:id="lblBirthDate" text="-" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                <Label text="Notas:" GridPane.rowIndex="5" GridPane.columnIndex="0" />
                <Label fx:id="lblNotes" text="Sin observaciones." wrapText="true" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
            </GridPane>
        </Tab>
        <Tab text="Historial de Préstamos">
            <graphic><FontIcon iconLiteral="fas-hand-holding-usd"/></graphic>
            <VBox style="-fx-padding: 10;" spacing="5">
                <TableView fx:id="tableCustomerLoans" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colLoanId" text="#" prefWidth="50"/>
                        <TableColumn fx:id="colLoanAmount" text="Monto" prefWidth="120"/>
                        <TableColumn fx:id="colLoanRemaining" text="Restante" prefWidth="120"/>
                        <TableColumn fx:id="colLoanStatus" text="Estado" prefWidth="100"/>
                        <TableColumn fx:id="colLoanDate" text="Fecha" prefWidth="110"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>
    </TabPane>

    <HBox alignment="CENTER_RIGHT">
        <Button text="Cerrar" onAction="#handleClose" styleClass="btn,btn-secondary"/>
    </HBox>
</VBox>