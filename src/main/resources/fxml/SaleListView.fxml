<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.edj.developer.apploans.controller.SaleController"
      styleClass="view-root"
      spacing="0">

    <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12">
        <VBox alignment="CENTER_LEFT" spacing="2">
            <Label text="Financiamiento de Productos" styleClass="topbar-title"/>
            <HBox spacing="6" alignment="CENTER_LEFT">
                <Label text="Panel Principal" styleClass="breadcrumb-link"/>
                <Label text="/" styleClass="text-muted"/>
                <Label text="Ventas" styleClass="text-muted text-sm"/>
            </HBox>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnNewSale"
                text="Nueva Venta"
                onAction="#handleNewSale"
                styleClass="btn,btn-primary"
                mnemonicParsing="false">
            <graphic>
                <FontIcon iconLiteral="fas-cart-plus" iconSize="14" iconColor="white"/>
            </graphic>
        </Button>
        <Label styleClass="user-avatar" text="AD"/>
    </HBox>

    <HBox spacing="16" styleClass="stats-bar">
        <VBox styleClass="stat-card stat-card-primary" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="14">
                <FontIcon iconLiteral="fas-shopping-bag" styleClass="stat-icon-primary"/>
                <VBox>
                    <Label fx:id="lblTotalSales" text="0" styleClass="stat-value"/>
                    <Label text="TOTAL VENTAS" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox styleClass="stat-card stat-card-success" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="14">
                <FontIcon iconLiteral="fas-hand-holding-usd" styleClass="stat-icon-success"/>
                <VBox>
                    <Label fx:id="lblTotalInvoiced" text="0,00" styleClass="stat-value"/>
                    <Label text="TOTAL FINANCIADO" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox styleClass="stat-card stat-card-warning" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="14">
                <FontIcon iconLiteral="fas-clock" styleClass="stat-icon-warning"/>
                <VBox>
                    <Label fx:id="lblActiveSales" text="0" styleClass="stat-value"/>
                    <Label text="CUENTAS ACTIVAS" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>
    </HBox>

    <VBox VBox.vgrow="ALWAYS" styleClass="card" spacing="0">
        <HBox styleClass="card-header" spacing="10" alignment="CENTER_LEFT">
            <FontIcon iconLiteral="fas-list" iconSize="15" iconColor="#495057"/>
            <Label text="Historial de Ventas Directas" styleClass="card-title"/>
            <Region HBox.hgrow="ALWAYS"/>

            <HBox spacing="6" alignment="CENTER">
                <FontIcon iconLiteral="fas-search" iconSize="13" iconColor="#6C757D"/>
                <TextField fx:id="txtSearch"
                           promptText="Buscar por cliente o producto..."
                           styleClass="search-field"
                           prefWidth="270"/>
            </HBox>

            <ComboBox fx:id="cmbStatusFilter"
                      promptText="Todos los estados"
                      styleClass="form-control"
                      prefWidth="160"/>

            <Button fx:id="btnRefresh"
                    styleClass="btn,btn-secondary,btn-sm,btn-icon"
                    onAction="#handleRefresh"
                    mnemonicParsing="false">
                <tooltip><Tooltip text="Actualizar lista"/></tooltip>
                <graphic>
                    <FontIcon iconLiteral="fas-sync-alt" iconSize="13" iconColor="#495057"/>
                </graphic>
            </Button>
        </HBox>

        <TableView fx:id="tableSales" VBox.vgrow="ALWAYS" styleClass="app-table">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            <placeholder>
                <VBox alignment="CENTER" spacing="10">
                    <FontIcon iconLiteral="fas-shopping-cart" iconSize="44" iconColor="#CED4DA"/>
                    <Label text="No se registraron ventas financieras" styleClass="empty-state-text"/>
                </VBox>
            </placeholder>
            <columns>
                <TableColumn fx:id="colId" text="#" prefWidth="50" minWidth="40"/>
                <TableColumn fx:id="colCustomer" text="CLIENTE" prefWidth="200" minWidth="150"/>
                <TableColumn fx:id="colProduct" text="PRODUCTO" prefWidth="180" minWidth="130"/>
                <TableColumn fx:id="colPrice" text="PRECIO VENTA" prefWidth="120" minWidth="90"/>
                <TableColumn fx:id="colInterests" text="INT. (%)" prefWidth="70" minWidth="60"/>
                <TableColumn fx:id="colTotal" text="TOTAL COBRAR" prefWidth="130" minWidth="100"/>
                <TableColumn fx:id="colInstallments" text="CUOTAS" prefWidth="90" minWidth="70"/>
                <TableColumn fx:id="colStatus" text="ESTADO" prefWidth="100" minWidth="80"/>
                <TableColumn fx:id="colActions" text="ACCIONES" prefWidth="90" minWidth="80" sortable="false"/>
            </columns>
        </TableView>

        <HBox styleClass="card-footer" spacing="12" alignment="CENTER">
            <Label fx:id="lblPageInfo" text="Mostrando 0 – 0 de 0 registros" styleClass="text-muted text-sm"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Pagination fx:id="pagination" pageCount="1" currentPageIndex="0" styleClass="pagination" HBox.hgrow="NEVER"/>
        </HBox>
    </VBox>
</VBox>