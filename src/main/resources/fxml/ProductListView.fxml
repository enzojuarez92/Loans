<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>
<?import java.lang.String?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.edj.developer.apploans.controller.ProductController"
      styleClass="view-root"
      spacing="0">

    <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12">
        <VBox alignment="CENTER_LEFT" spacing="2">
            <Label text="Gestión de Productos" styleClass="topbar-title"/>
            <HBox spacing="6" alignment="CENTER_LEFT">
                <Label text="Panel Principal" styleClass="breadcrumb-link"/>
                <Label text="/" styleClass="text-muted"/>
                <Label text="Productos" styleClass="text-muted text-sm"/>
            </HBox>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnNewProduct"
                text="Nuevo Producto"
                onAction="#handleNewProduct"
                styleClass="btn,btn-primary"
                mnemonicParsing="false">
            <graphic>
                <FontIcon iconLiteral="fas-plus" iconSize="14" iconColor="white"/>
            </graphic>
        </Button>
        <Label styleClass="user-avatar" text="AD"/>
    </HBox>

    <HBox spacing="16" styleClass="stats-bar">
        <VBox styleClass="stat-card stat-card-primary" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="14">
                <FontIcon iconLiteral="fas-boxes" styleClass="stat-icon-primary"/>
                <VBox>
                    <Label fx:id="lblTotalProducts" text="0" styleClass="stat-value"/>
                    <Label text="TOTAL PRODUCTOS" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox styleClass="stat-card stat-card-success" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="14">
                <FontIcon iconLiteral="fas-check-circle" styleClass="stat-icon-success"/>
                <VBox>
                    <Label fx:id="lblInStock" text="0" styleClass="stat-value"/>
                    <Label text="CON STOCK" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox styleClass="stat-card stat-card-warning" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="14">
                <FontIcon iconLiteral="fas-exclamation-triangle" styleClass="stat-icon-warning"/>
                <VBox>
                    <Label fx:id="lblLowStock" text="0" styleClass="stat-value"/>
                    <Label text="STOCK BAJO (&lt; 5)" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox styleClass="stat-card stat-card-danger" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="14">
                <FontIcon iconLiteral="fas-times-circle" styleClass="stat-icon-danger"/>
                <VBox>
                    <Label fx:id="lblNoStock" text="0" styleClass="stat-value"/>
                    <Label text="SIN STOCK" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>
    </HBox>

    <VBox VBox.vgrow="ALWAYS" styleClass="card" spacing="0">
        <HBox styleClass="card-header" spacing="10" alignment="CENTER_LEFT">
            <FontIcon iconLiteral="fas-list" iconSize="15" iconColor="#495057"/>
            <Label text="Listado de Inventario" styleClass="card-title"/>
            <Region HBox.hgrow="ALWAYS"/>

            <HBox spacing="6" alignment="CENTER">
                <FontIcon iconLiteral="fas-search" iconSize="13" iconColor="#6C757D"/>
                <TextField fx:id="txtSearch"
                           promptText="Buscar por nombre o descripción..."
                           styleClass="search-field"
                           prefWidth="270"/>
            </HBox>

            <ComboBox fx:id="cmbStockFilter"
                      promptText="Todos los niveles"
                      styleClass="form-control"
                      prefWidth="150"/>

            <Button fx:id="btnRefresh"
                    styleClass="btn btn-secondary btn-sm btn-icon"
                    onAction="#handleRefresh"
                    mnemonicParsing="false">
                <tooltip><Tooltip text="Actualizar lista"/></tooltip>
                <graphic>
                    <FontIcon iconLiteral="fas-sync-alt" iconSize="13" iconColor="#495057"/>
                </graphic>
            </Button>
        </HBox>

        <TableView fx:id="tableProducts"
                   VBox.vgrow="ALWAYS"
                   styleClass="app-table">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            <placeholder>
                <VBox alignment="CENTER" spacing="10">
                    <FontIcon iconLiteral="fas-box-open" iconSize="44" iconColor="#CED4DA"/>
                    <Label text="No se encontraron productos" styleClass="empty-state-text"/>
                    <Label text="Intente ajustar la búsqueda o los filtros" styleClass="text-muted text-sm"/>
                </VBox>
            </placeholder>
            <columns>
                <TableColumn fx:id="colId" text="#" prefWidth="50" minWidth="40"/>
                <TableColumn fx:id="colName" text="NOMBRE" prefWidth="220" minWidth="150"/>
                <TableColumn fx:id="colDescription" text="DESCRIPCIÓN" prefWidth="280" minWidth="180"/>
                <TableColumn fx:id="colBasePrice" text="PRECIO BASE" prefWidth="130" minWidth="100"/>
                <TableColumn fx:id="colStock" text="STOCK DISPONIBLE" prefWidth="130" minWidth="100"/>
                <TableColumn fx:id="colCreatedAt" text="FECHA REGISTRO" prefWidth="120" minWidth="100"/>
                <TableColumn fx:id="colActions" text="ACCIONES" prefWidth="100" minWidth="90" sortable="false"/>
            </columns>
        </TableView>

        <HBox styleClass="card-footer" spacing="12" alignment="CENTER">
            <Label fx:id="lblPageInfo" text="Mostrando 0 – 0 de 0 registros" styleClass="text-muted text-sm"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="6" alignment="CENTER">
                <Label text="Ver:" styleClass="text-muted text-sm"/>
                <ComboBox fx:id="cmbPageSize" prefWidth="100" styleClass="form-control"/>
                <Label text="por pág." styleClass="text-muted text-sm"/>
            </HBox>
            <Pagination fx:id="pagination" pageCount="1" currentPageIndex="0" styleClass="pagination" HBox.hgrow="NEVER"/>
        </HBox>
    </VBox>
</VBox>